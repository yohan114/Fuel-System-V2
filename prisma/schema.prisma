datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String        @id @default(uuid())
  username         String        @unique
  email            String?
  name             String
  passwordHash     String
  role             String        // "ADMIN" | "USER" | "ALLOCATOR" | "WORKSHOP"
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  createdById      String?
  createdBy        User?         @relation("CreatedByUser", fields: [createdById], references: [id])
  createdUsers     User[]        @relation("CreatedByUser")

  projectId        String?
  project          Project?      @relation(fields: [projectId], references: [id])

  bulkTankId       String?
  bulkTank         BulkTank?     @relation(fields: [bulkTankId], references: [id])

  enteredPrices    FuelPrice[]
  fuelRequests     FuelRequest[] @relation("RequestedBy")
  reviewedRequests FuelRequest[] @relation("ReviewedBy")
  fuelIssues       FuelIssue[]   @relation("IssuedBy")
  meterReadings    MeterReading[] @relation("RecordedBy")
  dailyConditions  DailyCondition[] @relation("RecordedBy")
  auditLogs        AuditLog[]    @relation("Actor")

  bulkRequests     BulkRequest[] @relation("BulkRequestedBy")
  reviewedBulk     BulkRequest[] @relation("BulkReviewedBy")

  generatedBills   Bill[]        @relation("BillGeneratedBy")
  createdAssignments AssetAssignment[] @relation("AssignmentCreatedBy")

  fuelCorrections     FuelIssueCorrection[] @relation("CorrectionRequestedBy")
  reviewedCorrections FuelIssueCorrection[] @relation("CorrectionReviewedBy")

  tankDips         TankDip[]     @relation("TankDipRecordedBy")

  serviceRecords   ServiceRecord[] @relation("ServiceRecordedBy")
  serviceAttachments ServiceAttachment[] @relation("AttachmentUploadedBy")
}

model Category {
  id               String        @id @default(uuid())
  code             String        @unique // e.g. DT, HEX, VR
  name             String
  defaultMeterType String        // "KM" | "HOURS"
  fleetGroup       String        // "ROAD_VEHICLE" | "MACHINERY_GENSET"
  assets           Asset[]
  serviceInterval  ServiceInterval?
}

model Asset {
  id            String         @id @default(uuid())
  code          String         @unique // E&C number (e.g. DT-123)
  brand         String?
  typeLabel     String?        // e.g. SANY, TATA
  model         String?
  regNo         String?
  capacity      String?
  yom           Int?
  chassisNo     String?
  engineNo      String?
  serialNo      String?
  site          String?
  status        String         @default("ACTIVE") // "ACTIVE" | "INACTIVE" | "DISPOSED"
  meterType     String         // "KM" | "HOURS"
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])

  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id])

  fuelRequests  FuelRequest[]
  fuelIssues    FuelIssue[]
  meterReadings MeterReading[]
  dailyConditions DailyCondition[]
  assignments   AssetAssignment[]

  rentalRate    RentalRate?
  bills         Bill[]
  serviceRecords ServiceRecord[]
  serviceIntervalOverride ServiceInterval?
}

// A saved, time-bounded posting of one asset to one project/site. This is the
// authoritative record of "which vehicle was assigned where, and when" — it
// replaces guessing a vehicle's site from its fuel/reading source strings.
//
// A vehicle can hold several assignments across a month (e.g. week 1 at site X,
// week 2 at site Y, weeks 3-4 at site Z); billing splits the month along these
// segments. Dates are Colombo local-midnight day markers. endDate is the
// inclusive last day; a null endDate means the posting is still open/ongoing.
model AssetAssignment {
  id          String    @id @default(uuid())

  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])

  startDate   DateTime  // inclusive first day (Colombo midnight)
  endDate     DateTime? // inclusive last day; null = ongoing
  note        String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String?
  createdBy   User?     @relation("AssignmentCreatedBy", fields: [createdById], references: [id])

  @@index([assetId, startDate])
  @@index([projectId, startDate])
}

model FuelPrice {
  id             String      @id @default(uuid())
  fuelKind       String      // "AUTO_DIESEL" | "SUPER_DIESEL"
  pricePerLitre  Int         // in LKR cents
  effectiveFrom  DateTime
  source         String      // "CEYPETCO" | "MANUAL"
  note           String?
  createdAt      DateTime    @default(now())

  enteredById    String
  enteredBy      User        @relation(fields: [enteredById], references: [id])

  fuelIssues     FuelIssue[]

  @@unique([fuelKind, effectiveFrom])
  @@index([fuelKind, effectiveFrom])
}

model FuelRequest {
  id             String      @id @default(uuid())
  fuelKind       String      // "AUTO_DIESEL" | "SUPER_DIESEL"
  requestedLitres Float
  meterReading   Float?
  readingType    String?     // "KM" | "HOURS"
  reason         String?
  status         String      @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  assetId        String
  asset          Asset       @relation(fields: [assetId], references: [id])

  requestedById  String
  requestedBy    User        @relation("RequestedBy", fields: [requestedById], references: [id])

  reviewedById   String?
  reviewedBy     User?       @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  reviewNote     String?

  // Optional pump/meter photo proof captured by the site PM at request time;
  // copied onto the resulting FuelIssue when the request is approved.
  photoData      Bytes?
  photoName      String?
  photoMime      String?

  issue          FuelIssue?
}

model FuelIssue {
  id             String       @id @default(uuid())
  fuelKind       String       // "AUTO_DIESEL" | "SUPER_DIESEL"
  litres         Float
  meterReading   Float?
  readingType    String?      // "KM" | "HOURS"
  pricePerLitre  Int          // in LKR cents snapshot
  totalCost      Int          // in LKR cents calculated
  source         String       // "STATION" | "BOWSER"
  issueDate      DateTime
  createdAt      DateTime     @default(now())

  assetId        String
  asset          Asset        @relation(fields: [assetId], references: [id])

  issuedById     String
  issuedBy       User         @relation("IssuedBy", fields: [issuedById], references: [id])

  fuelPriceId    String?
  fuelPrice      FuelPrice?   @relation(fields: [fuelPriceId], references: [id])

  linkedRequestId String?     @unique
  linkedRequest   FuelRequest? @relation(fields: [linkedRequestId], references: [id])

  meterReadingRecordId String? @unique
  meterReadingRecord   MeterReading? @relation("LinkedIssueMeterReading")

  bulkTankId      String?
  bulkTank        BulkTank?    @relation("TankIssues", fields: [bulkTankId], references: [id])

  // Soft-void: a wrong/duplicate issue is voided (not deleted) via an approved
  // correction. Voided issues are excluded from billing, fuel sums and reports
  // but kept for the audit trail.
  voided          Boolean      @default(false)
  voidedAt        DateTime?

  // Optional pump/meter photo proof for the issue (carried from the request,
  // or attached directly on a direct issue).
  photoData       Bytes?
  photoName       String?
  photoMime       String?

  corrections     FuelIssueCorrection[]
}

// An admin-approved error-correction request against a fuel issue. A site user
// submits it with a mandatory signed running-chart document (stored inline so
// it travels with DB backups); an admin approves (applies the edit / voids the
// issue) or rejects. Every request is a permanent, site-stamped log entry.
model FuelIssueCorrection {
  id            String    @id @default(uuid())

  fuelIssueId   String
  fuelIssue     FuelIssue @relation(fields: [fuelIssueId], references: [id], onDelete: Cascade)

  type          String    // "EDIT" | "VOID"
  status        String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  reason        String

  // Proposed new values (EDIT only; null = leave that field unchanged).
  newLitres        Float?
  newMeterReading  Float?
  newReadingType   String?
  newFuelKind      String?
  newIssueDate     DateTime?

  // Original values snapshotted at request time, for the before/after log.
  origLitres       Float
  origMeterReading Float?
  origFuelKind     String
  origIssueDate    DateTime
  origSource       String

  // Site snapshot (so the activity log sorts/filters site-wise even if the
  // vehicle is later reassigned).
  assetId       String
  assetCode     String
  projectId     String?
  projectName   String?
  projectCode   String?

  // Required evidence document (photo/PDF of the signed running chart), stored
  // as a BLOB so it is captured by the existing database backups.
  docData       Bytes
  docName       String
  docMime       String

  requestedById String
  requestedBy   User      @relation("CorrectionRequestedBy", fields: [requestedById], references: [id])

  reviewedById  String?
  reviewedBy    User?     @relation("CorrectionReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  reviewNote    String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, projectCode])
  @@index([projectCode, createdAt])
  @@index([fuelIssueId])
}

model MeterReading {
  id             String     @id @default(uuid())
  value          Float      // cumulative odometer or hour meter
  readingType    String     // "KM" | "HOURS"
  readingDate    DateTime
  source         String     // "MANUAL" | "FUEL_ISSUE"
  createdAt      DateTime   @default(now())

  assetId        String
  asset          Asset      @relation(fields: [assetId], references: [id])

  recordedById   String
  recordedBy     User       @relation("RecordedBy", fields: [recordedById], references: [id])

  linkedIssueId  String?    @unique
  linkedIssue    FuelIssue? @relation("LinkedIssueMeterReading", fields: [linkedIssueId], references: [id])
}

model AuditLog {
  id             String    @id @default(uuid())
  action         String    // "CREATE" | "UPDATE" | "DELETE" | "APPROVE" | "REJECT" | "LOGIN" | "PRICE_REFRESH" | "BACKUP"
  entity         String    // e.g. "Asset", "FuelIssue"
  entityId       String?
  summary        String
  metaJson       String?   // JSON payload details
  createdAt      DateTime  @default(now())

  actorId        String?
  actor          User?     @relation("Actor", fields: [actorId], references: [id])
}

model Setting {
  id             String    @id @default(uuid())
  key            String    @unique
  value          String
  updatedAt      DateTime  @updatedAt
}

model Project {
  id           String   @id @default(uuid())
  name         String   @unique
  code         String   @unique
  contactName  String?
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  assets      Asset[]
  bulkTanks   BulkTank[]
  assignments AssetAssignment[]
  budgets     Budget[]
}

model DailyCondition {
  id           String   @id @default(uuid())
  status       String   // "WORKING" | "BREAKDOWN"
  logDate      DateTime // truncated to midnight YYYY-MM-DD
  note         String?
  createdAt    DateTime @default(now())

  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])

  recordedById String
  recordedBy   User     @relation("RecordedBy", fields: [recordedById], references: [id])

  @@unique([assetId, logDate])
  @@index([assetId, logDate])
}

model BulkTank {
  id        String   @id @default(uuid())
  name      String   @unique
  fuelKind  String   // "AUTO_DIESEL" | "SUPER_DIESEL"
  capacity  Float
  balance   Float    @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id])

  users     User[]
  requests  BulkRequest[]
  issues    FuelIssue[]   @relation("TankIssues")
  dips      TankDip[]
}

// A physical bulk-tank dip/count, recorded periodically to reconcile the
// measured fuel level against the system-computed balance (top-ups − issues).
// A persistent gap flags shrinkage, leakage or unrecorded draws.
model TankDip {
  id              String   @id @default(uuid())

  bulkTankId      String
  bulkTank        BulkTank @relation(fields: [bulkTankId], references: [id], onDelete: Cascade)

  dipLitres       Float    // physically measured litres in the tank
  computedBalance Float    // system balance snapshot at dip time
  variance        Float    // dipLitres − computedBalance (negative = shortfall)
  dipDate         DateTime
  note            String?
  createdAt       DateTime @default(now())

  recordedById    String
  recordedBy      User     @relation("TankDipRecordedBy", fields: [recordedById], references: [id])

  @@index([bulkTankId, dipDate])
}

model BulkRequest {
  id              String    @id @default(uuid())
  fuelKind        String    // "AUTO_DIESEL" | "SUPER_DIESEL"
  requestedLitres Float
  status          String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bulkTankId      String
  bulkTank        BulkTank  @relation(fields: [bulkTankId], references: [id])

  requestedById   String
  requestedBy     User      @relation("BulkRequestedBy", fields: [requestedById], references: [id])

  reviewedById    String?
  reviewedBy      User?     @relation("BulkReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewNote      String?
}

// Per-asset machine rental rate card, imported from the E&C Machine Rental
// Calculator. Rates are stored in LKR cents (whole-LKR source × 100). A null
// tier means that combination is not available for the machine.
model RentalRate {
  id            String   @id @default(uuid())

  assetId       String   @unique
  asset         Asset    @relation(fields: [assetId], references: [id])

  sourceLabel   String?  // original "label" from the rate card
  category      String?  // source "cat"
  equipType     String   @default("FLEET") // "FLEET" | "PORTABLE"

  fuelQtyDefault Float?  // source "fuel" hint (not used for billing fuel cost)
  opRate         Int?    // source "op" operator rate, cents (reserved)

  // Hourly tier (cents)
  hrFwCents     Int?
  hrWCents      Int?
  hrDCents      Int?
  // Per-day tier (cents)
  dyFwCents     Int?
  dyWCents      Int?
  dyDCents      Int?
  // Per-km tier (cents)
  kmFwCents     Int?
  kmWCents      Int?
  kmDCents      Int?

  // Portable equipment: per-day only, 2-tier (dw = day wet, dd = day dry)
  portDwCents   Int?
  portDdCents   Int?

  // Fuel consumption rates from the Fuel Rates sheet (L/hr or L/km)
  fuelConsEcon  Float?   // economic (light load) consumption
  fuelConsTyp   Float?   // typical consumption
  fuelConsBasis String?  // "hr" | "km"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// One monthly bill per asset. Acts as both a cost statement and an invoice.
// All money columns are LKR cents and fully snapshotted at generation time so a
// finalized bill is immutable even if the underlying issues/readings change.
model Bill {
  id            String   @id @default(uuid())

  // Period (Colombo month)
  year          Int
  month         Int      // 1-12
  periodKey     String   // "2026-05"
  periodStart   DateTime
  periodEnd     DateTime

  // Asset / site snapshot
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  assetCode     String
  assetRegNo    String?
  assetLabel    String?
  projectId     String?
  projectName   String?
  projectCode   String?

  // Billing config snapshot
  billingMode   String   // "hourly" | "perkm" | "perday"
  rateBasis     String   // "fw" | "w" | "d"
  rateCents     Int

  // Usage derivation snapshot
  openingMeter  Float?
  closingMeter  Float?
  actualUnits   Float
  minimumUnits  Float
  billableUnits Float

  // Money (cents)
  rentalAmountCents Int
  fuelLitres        Float @default(0)
  fuelCostCents     Int   @default(0)
  subtotalCents     Int
  ssclRate          Float
  ssclCents         Int
  vatRate           Float
  vatCents          Int
  grandTotalCents   Int

  // Invoice fields
  invoiceNumber String?  @unique
  status        String   @default("DRAFT") // "DRAFT" | "ISSUED" | "PAID" | "OVERDUE"
  issuedDate    DateTime?
  dueDate       DateTime?
  paidDate      DateTime?
  paidAmountCents Int?
  paymentRef    String?
  paymentNote   String?

  notes         String?

  // Fuel-derived units (when no meter readings exist)
  derivedFromFuel Boolean @default(false)
  fuelConsMidRate Float?  // mid consumption rate used (L/hr or L/km)

  // Fuel-derived options and raw meter units
  actualMeterUnits     Float?
  derivedStandardUnits Float?
  derivedEconUnits     Float?
  fuelConsEconSnapshot Float?
  fuelConsTypSnapshot  Float?

  // Breakdown deduction
  breakdownDays        Int @default(0)
  breakdownDeductCents Int @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generatedById String?
  generatedBy   User?    @relation("BillGeneratedBy", fields: [generatedById], references: [id])

  // Invoice email dispatch stamp.
  emailedAt     DateTime?
  emailedTo     String?

  lineItems     BillLineItem[]
  creditNotes   CreditNote[]

  @@unique([assetId, year, month])
  @@index([periodKey, status])
  @@index([projectId, periodKey])
}

model BillLineItem {
  id          String  @id @default(uuid())

  billId      String
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)

  kind        String  // "RENTAL" | "FUEL" | "ADJUSTMENT"
  description String
  quantity    Float
  unit        String  // "hr" | "km" | "day" | "L" | "—"
  unitRateCents Int
  amountCents Int

  // Per-site attribution. When a vehicle works several sites in one month the
  // bill carries one RENTAL (+ optional FUEL) line per site; these record which
  // site the line belongs to. Null for single-site / legacy bills.
  projectId   String?
  projectName String?

  @@index([billId])
}

// Per-site monthly fuel budget, for budget-vs-actual tracking and month-end
// run-rate forecasting.
model Budget {
  id                String   @id @default(uuid())

  projectId         String
  project           Project  @relation(fields: [projectId], references: [id])

  year              Int
  month             Int      // 1-12
  budgetLitres      Float?
  budgetAmountCents Int?
  note              String?

  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([projectId, year, month])
  @@index([year, month])
}

// A credit note against an issued bill (correction/discount/goodwill). Reduces
// the outstanding receivable for that invoice once issued.
model CreditNote {
  id          String   @id @default(uuid())

  billId      String
  bill        Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  number      String?  @unique
  reason      String
  amountCents Int      // positive amount credited back to the customer
  status      String   @default("DRAFT") // "DRAFT" | "ISSUED"

  createdById String?
  createdAt   DateTime @default(now())
  issuedDate  DateTime?

  @@index([billId])
}

// Service interval config. One row per category (the editable default) and/or
// one per asset (an override). Resolution precedence: asset → category →
// hard-coded fleet-group default (machinery 500 hr / road 5,000 km).
model ServiceInterval {
  id             String    @id @default(uuid())

  categoryId     String?   @unique
  category       Category? @relation(fields: [categoryId], references: [id])

  assetId        String?   @unique
  asset          Asset?    @relation(fields: [assetId], references: [id])

  basis          String    // "HOURS" | "KM"
  intervalValue  Float
  intervalMonths Int?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// A logged completed service. The countdown to the next service resets at the
// latest record's date (and meterAtService when supplied).
//
// Phase 1 of the Fuel + Service merge deepens this into a full service sheet
// (merged from the standalone Service Record system): a header, an oils matrix,
// a filters matrix, free-form cost lines and the labour/sundry money breakdown.
// All money is stored in LKR cents to match the rest of the system. `costCents`
// is kept as a mirror of `grandTotalCents` so existing displays keep working.
model ServiceRecord {
  id             String   @id @default(uuid())

  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  serviceDate    DateTime
  meterAtService Float?
  meterType      String   // "HOURS" | "KM"
  serviceType    String?
  costCents      Int?     // legacy/grand-total mirror (kept for existing displays)
  note           String?

  // --- Detailed service-sheet header (merged from the Service Record system) ---
  jobNo            String?
  siteLocation     String?
  nextServiceMeter Float?
  upkeepingStatus  String?  // e.g. "GOOD" | "NEEDS_REPAIR"
  repairDetails    String?

  // --- Money breakdown (LKR cents) ---
  partsSubtotalCents Int   @default(0)
  labourRatePct      Float @default(0) // % actually applied (low/high band)
  labourChargeCents  Int   @default(0)
  sundryRatePct      Float @default(0)
  sundryAmountCents  Int   @default(0)
  grandTotalCents    Int   @default(0)

  recordedById   String
  recordedBy     User     @relation("ServiceRecordedBy", fields: [recordedById], references: [id])

  createdAt      DateTime @default(now())

  // Provenance for bulk imports (e.g. "servicedb:1573"); lets re-runs skip
  // already-imported rows. Null for records created in-app.
  sourceRef      String?  @unique

  oils        ServiceOil[]
  filters     ServiceFilter[]
  costLines   ServiceCostLine[]
  attachments ServiceAttachment[]

  @@index([assetId, serviceDate])
  @@index([jobNo])
}

// One oil line on a service sheet (e.g. "Engine Oil" → grade "15W40-CI/04",
// 12 L, Rs ...). `oilName` matches an OilType master row.
model ServiceOil {
  id              String        @id @default(uuid())

  serviceRecordId String
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  oilName    String  // master oil-line name (e.g. "Engine Oil")
  oilType    String? // chosen grade/code (e.g. "15W40-CI/04")
  actionType String? // C/V marker (change / verify) — free text
  quantity   Float   @default(0)
  priceCents Int     @default(0)

  @@index([serviceRecordId])
}

// One filter line on a service sheet. `filterCategory` matches a
// FilterCategoryRef master row; `filterNo` is the part number fitted.
model ServiceFilter {
  id              String        @id @default(uuid())

  serviceRecordId String
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  filterCategory String  // master filter-category name (e.g. "Air Filter")
  filterNo       String? // part number fitted
  actionType     String? // X/E marker (exchange / existing) — free text
  quantity       Int     @default(1)
  priceCents     Int     @default(0)

  @@index([serviceRecordId])
}

// A free-form additional cost line on a service sheet (labour items, sundries
// entered by hand, sublet work, etc.).
model ServiceCostLine {
  id              String        @id @default(uuid())

  serviceRecordId String
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  description String?
  unit        String?
  rateCents   Int     @default(0)
  qty         Float   @default(0)
  amountCents Int     @default(0)

  @@index([serviceRecordId])
}

// Master list of oil lines shown on the service sheet (one row per oil line).
// Editable later; seeded with the Service Record system's defaults.
model OilType {
  id             String  @id @default(uuid())
  name           String  @unique
  unit           String  @default("L")
  unitPriceCents Int     @default(0)
  sortOrder      Int     @default(0)
  active         Boolean @default(true)
}

// Master list of filter categories shown on the service sheet (one row per
// filter line). Named *Ref to avoid clashing with the asset `Category` model.
model FilterCategoryRef {
  id             String  @id @default(uuid())
  name           String  @unique
  unitPriceCents Int     @default(0)
  sortOrder      Int     @default(0)
  active         Boolean @default(true)
}

// ===========================================================================
// Phase 2 of the Fuel + Service merge: the filter cross-reference engine and
// editable price books (merged from the Service Record system's catalog).
// ===========================================================================

// The filter catalog — one row per filter, with its OEM / HIFI numbers and the
// free-text cross-reference string that the engine parses into FilterCrossRef.
model FilterCatalog {
  id              String   @id @default(uuid())
  sourceId        Int?     @unique // original id from the catalog dump (re-import key)
  filterCategory  String?
  oemPartNumber   String?
  hifiPartNumber  String?
  description     String?
  compatibleFleet String?         // free-text compatible fleet types
  crossRefText    String?         // raw cross-reference string
  monthlyDemand   Float?          // from the source filter analysis
  annualDemand    Float?
  serviceCount    Int?            // historical service uses
  vehicleCount    Int?            // distinct vehicles using it
  createdAt       DateTime @default(now())

  crossRefs    FilterCrossRef[]
  vehicleLinks FilterVehicleLink[]

  @@index([filterCategory])
}

// Normalized cross-reference index — one row per (filter, part-number) pair.
// Auto rows are rebuilt from the catalog; manual rows (added in the UI) carry
// source='manual' and survive a rebuild.
model FilterCrossRef {
  id           String        @id @default(uuid())
  catalogId    String
  catalog      FilterCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  brand        String        @default("")
  partNumber   String
  normalizedPN String // uppercase, alphanumeric-only key used for matching
  refType      String        @default("cross") // "oem" | "hifi" | "cross" | "manual"
  note         String        @default("")
  source       String        @default("auto") // "auto" | "manual"
  createdAt    DateTime      @default(now())

  @@index([normalizedPN])
  @@index([catalogId])
  @@index([brand])
}

// Filter → machine usage, by E&C code. Matched to Asset.code at query time so
// the catalog stays decoupled from the live fleet table.
model FilterVehicleLink {
  id        String        @id @default(uuid())
  catalogId String
  catalog   FilterCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  ec        String // E&C code (maps to Asset.code)

  @@index([catalogId])
  @@index([ec])
}

// Editable filter price book — drives the auto-fill of filter prices on the
// service sheet (looked up by normalized supplier code).
model FilterPrice {
  id              String   @id @default(uuid())
  supplierCode    String
  normalizedCode  String   @default("") // normalize(supplierCode) for lookup
  description     String?
  qty             Int      @default(1)
  unitPriceCents  Int      @default(0)
  totalPriceCents Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([normalizedCode])
}

// Editable oil-grade price list (grade code → price) — drives oil price
// auto-fill on the service sheet.
model OilPrice {
  id             String  @id @default(uuid())
  code           String  @unique // e.g. "15W40-CI/04"
  description    String?
  unitPriceCents Int     @default(0)
}

// Phase 3 of the merge: file attachments on a service record (PDF / images /
// Office docs). Stored inline as Bytes — like FuelIssue.photoData and
// FuelIssueCorrection.docData — so they travel with the database backups.
model ServiceAttachment {
  id              String        @id @default(uuid())

  serviceRecordId String
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)

  data         Bytes
  originalName String
  mimeType     String?
  fileSize     Int      @default(0)
  caption      String   @default("")

  uploadedById String?
  uploadedBy   User?    @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  @@index([serviceRecordId])
}
