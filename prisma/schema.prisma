datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String        @id @default(uuid())
  username         String        @unique
  email            String?
  name             String
  passwordHash     String
  role             String        // "ADMIN" | "USER" | "ALLOCATOR" | "WORKSHOP"
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  createdById      String?
  createdBy        User?         @relation("CreatedByUser", fields: [createdById], references: [id])
  createdUsers     User[]        @relation("CreatedByUser")

  projectId        String?
  project          Project?      @relation(fields: [projectId], references: [id])

  bulkTankId       String?
  bulkTank         BulkTank?     @relation(fields: [bulkTankId], references: [id])

  enteredPrices    FuelPrice[]
  fuelRequests     FuelRequest[] @relation("RequestedBy")
  reviewedRequests FuelRequest[] @relation("ReviewedBy")
  fuelIssues       FuelIssue[]   @relation("IssuedBy")
  meterReadings    MeterReading[] @relation("RecordedBy")
  dailyConditions  DailyCondition[] @relation("RecordedBy")
  auditLogs        AuditLog[]    @relation("Actor")

  bulkRequests     BulkRequest[] @relation("BulkRequestedBy")
  reviewedBulk     BulkRequest[] @relation("BulkReviewedBy")

  generatedBills   Bill[]        @relation("BillGeneratedBy")
  createdAssignments AssetAssignment[] @relation("AssignmentCreatedBy")
}

model Category {
  id               String        @id @default(uuid())
  code             String        @unique // e.g. DT, HEX, VR
  name             String
  defaultMeterType String        // "KM" | "HOURS"
  fleetGroup       String        // "ROAD_VEHICLE" | "MACHINERY_GENSET"
  assets           Asset[]
}

model Asset {
  id            String         @id @default(uuid())
  code          String         @unique // E&C number (e.g. DT-123)
  brand         String?
  typeLabel     String?        // e.g. SANY, TATA
  model         String?
  regNo         String?
  capacity      String?
  yom           Int?
  chassisNo     String?
  engineNo      String?
  serialNo      String?
  site          String?
  status        String         @default("ACTIVE") // "ACTIVE" | "INACTIVE" | "DISPOSED"
  meterType     String         // "KM" | "HOURS"
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])

  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id])

  fuelRequests  FuelRequest[]
  fuelIssues    FuelIssue[]
  meterReadings MeterReading[]
  dailyConditions DailyCondition[]
  assignments   AssetAssignment[]

  rentalRate    RentalRate?
  bills         Bill[]
}

// A saved, time-bounded posting of one asset to one project/site. This is the
// authoritative record of "which vehicle was assigned where, and when" — it
// replaces guessing a vehicle's site from its fuel/reading source strings.
//
// A vehicle can hold several assignments across a month (e.g. week 1 at site X,
// week 2 at site Y, weeks 3-4 at site Z); billing splits the month along these
// segments. Dates are Colombo local-midnight day markers. endDate is the
// inclusive last day; a null endDate means the posting is still open/ongoing.
model AssetAssignment {
  id          String    @id @default(uuid())

  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])

  startDate   DateTime  // inclusive first day (Colombo midnight)
  endDate     DateTime? // inclusive last day; null = ongoing
  note        String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String?
  createdBy   User?     @relation("AssignmentCreatedBy", fields: [createdById], references: [id])

  @@index([assetId, startDate])
  @@index([projectId, startDate])
}

model FuelPrice {
  id             String      @id @default(uuid())
  fuelKind       String      // "AUTO_DIESEL" | "SUPER_DIESEL"
  pricePerLitre  Int         // in LKR cents
  effectiveFrom  DateTime
  source         String      // "CEYPETCO" | "MANUAL"
  note           String?
  createdAt      DateTime    @default(now())

  enteredById    String
  enteredBy      User        @relation(fields: [enteredById], references: [id])

  fuelIssues     FuelIssue[]

  @@unique([fuelKind, effectiveFrom])
  @@index([fuelKind, effectiveFrom])
}

model FuelRequest {
  id             String      @id @default(uuid())
  fuelKind       String      // "AUTO_DIESEL" | "SUPER_DIESEL"
  requestedLitres Float
  meterReading   Float?
  readingType    String?     // "KM" | "HOURS"
  reason         String?
  status         String      @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  assetId        String
  asset          Asset       @relation(fields: [assetId], references: [id])

  requestedById  String
  requestedBy    User        @relation("RequestedBy", fields: [requestedById], references: [id])

  reviewedById   String?
  reviewedBy     User?       @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  reviewNote     String?

  issue          FuelIssue?
}

model FuelIssue {
  id             String       @id @default(uuid())
  fuelKind       String       // "AUTO_DIESEL" | "SUPER_DIESEL"
  litres         Float
  meterReading   Float?
  readingType    String?      // "KM" | "HOURS"
  pricePerLitre  Int          // in LKR cents snapshot
  totalCost      Int          // in LKR cents calculated
  source         String       // "STATION" | "BOWSER"
  issueDate      DateTime
  createdAt      DateTime     @default(now())

  assetId        String
  asset          Asset        @relation(fields: [assetId], references: [id])

  issuedById     String
  issuedBy       User         @relation("IssuedBy", fields: [issuedById], references: [id])

  fuelPriceId    String?
  fuelPrice      FuelPrice?   @relation(fields: [fuelPriceId], references: [id])

  linkedRequestId String?     @unique
  linkedRequest   FuelRequest? @relation(fields: [linkedRequestId], references: [id])

  meterReadingRecordId String? @unique
  meterReadingRecord   MeterReading? @relation("LinkedIssueMeterReading")

  bulkTankId      String?
  bulkTank        BulkTank?    @relation("TankIssues", fields: [bulkTankId], references: [id])
}

model MeterReading {
  id             String     @id @default(uuid())
  value          Float      // cumulative odometer or hour meter
  readingType    String     // "KM" | "HOURS"
  readingDate    DateTime
  source         String     // "MANUAL" | "FUEL_ISSUE"
  createdAt      DateTime   @default(now())

  assetId        String
  asset          Asset      @relation(fields: [assetId], references: [id])

  recordedById   String
  recordedBy     User       @relation("RecordedBy", fields: [recordedById], references: [id])

  linkedIssueId  String?    @unique
  linkedIssue    FuelIssue? @relation("LinkedIssueMeterReading", fields: [linkedIssueId], references: [id])
}

model AuditLog {
  id             String    @id @default(uuid())
  action         String    // "CREATE" | "UPDATE" | "DELETE" | "APPROVE" | "REJECT" | "LOGIN" | "PRICE_REFRESH" | "BACKUP"
  entity         String    // e.g. "Asset", "FuelIssue"
  entityId       String?
  summary        String
  metaJson       String?   // JSON payload details
  createdAt      DateTime  @default(now())

  actorId        String?
  actor          User?     @relation("Actor", fields: [actorId], references: [id])
}

model Setting {
  id             String    @id @default(uuid())
  key            String    @unique
  value          String
  updatedAt      DateTime  @updatedAt
}

model Project {
  id           String   @id @default(uuid())
  name         String   @unique
  code         String   @unique
  contactName  String?
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  assets      Asset[]
  bulkTanks   BulkTank[]
  assignments AssetAssignment[]
}

model DailyCondition {
  id           String   @id @default(uuid())
  status       String   // "WORKING" | "BREAKDOWN"
  logDate      DateTime // truncated to midnight YYYY-MM-DD
  note         String?
  createdAt    DateTime @default(now())

  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])

  recordedById String
  recordedBy   User     @relation("RecordedBy", fields: [recordedById], references: [id])

  @@unique([assetId, logDate])
  @@index([assetId, logDate])
}

model BulkTank {
  id        String   @id @default(uuid())
  name      String   @unique
  fuelKind  String   // "AUTO_DIESEL" | "SUPER_DIESEL"
  capacity  Float
  balance   Float    @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id])

  users     User[]
  requests  BulkRequest[]
  issues    FuelIssue[]   @relation("TankIssues")
}

model BulkRequest {
  id              String    @id @default(uuid())
  fuelKind        String    // "AUTO_DIESEL" | "SUPER_DIESEL"
  requestedLitres Float
  status          String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bulkTankId      String
  bulkTank        BulkTank  @relation(fields: [bulkTankId], references: [id])

  requestedById   String
  requestedBy     User      @relation("BulkRequestedBy", fields: [requestedById], references: [id])

  reviewedById    String?
  reviewedBy      User?     @relation("BulkReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewNote      String?
}

// Per-asset machine rental rate card, imported from the E&C Machine Rental
// Calculator. Rates are stored in LKR cents (whole-LKR source × 100). A null
// tier means that combination is not available for the machine.
model RentalRate {
  id            String   @id @default(uuid())

  assetId       String   @unique
  asset         Asset    @relation(fields: [assetId], references: [id])

  sourceLabel   String?  // original "label" from the rate card
  category      String?  // source "cat"
  equipType     String   @default("FLEET") // "FLEET" | "PORTABLE"

  fuelQtyDefault Float?  // source "fuel" hint (not used for billing fuel cost)
  opRate         Int?    // source "op" operator rate, cents (reserved)

  // Hourly tier (cents)
  hrFwCents     Int?
  hrWCents      Int?
  hrDCents      Int?
  // Per-day tier (cents)
  dyFwCents     Int?
  dyWCents      Int?
  dyDCents      Int?
  // Per-km tier (cents)
  kmFwCents     Int?
  kmWCents      Int?
  kmDCents      Int?

  // Portable equipment: per-day only, 2-tier (dw = day wet, dd = day dry)
  portDwCents   Int?
  portDdCents   Int?

  // Fuel consumption rates from the Fuel Rates sheet (L/hr or L/km)
  fuelConsEcon  Float?   // economic (light load) consumption
  fuelConsTyp   Float?   // typical consumption
  fuelConsBasis String?  // "hr" | "km"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// One monthly bill per asset. Acts as both a cost statement and an invoice.
// All money columns are LKR cents and fully snapshotted at generation time so a
// finalized bill is immutable even if the underlying issues/readings change.
model Bill {
  id            String   @id @default(uuid())

  // Period (Colombo month)
  year          Int
  month         Int      // 1-12
  periodKey     String   // "2026-05"
  periodStart   DateTime
  periodEnd     DateTime

  // Asset / site snapshot
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  assetCode     String
  assetRegNo    String?
  assetLabel    String?
  projectId     String?
  projectName   String?
  projectCode   String?

  // Billing config snapshot
  billingMode   String   // "hourly" | "perkm" | "perday"
  rateBasis     String   // "fw" | "w" | "d"
  rateCents     Int

  // Usage derivation snapshot
  openingMeter  Float?
  closingMeter  Float?
  actualUnits   Float
  minimumUnits  Float
  billableUnits Float

  // Money (cents)
  rentalAmountCents Int
  fuelLitres        Float @default(0)
  fuelCostCents     Int   @default(0)
  subtotalCents     Int
  ssclRate          Float
  ssclCents         Int
  vatRate           Float
  vatCents          Int
  grandTotalCents   Int

  // Invoice fields
  invoiceNumber String?  @unique
  status        String   @default("DRAFT") // "DRAFT" | "ISSUED" | "PAID" | "OVERDUE"
  issuedDate    DateTime?
  dueDate       DateTime?
  paidDate      DateTime?
  paidAmountCents Int?
  paymentRef    String?
  paymentNote   String?

  notes         String?

  // Fuel-derived units (when no meter readings exist)
  derivedFromFuel Boolean @default(false)
  fuelConsMidRate Float?  // mid consumption rate used (L/hr or L/km)

  // Fuel-derived options and raw meter units
  actualMeterUnits     Float?
  derivedStandardUnits Float?
  derivedEconUnits     Float?
  fuelConsEconSnapshot Float?
  fuelConsTypSnapshot  Float?

  // Breakdown deduction
  breakdownDays        Int @default(0)
  breakdownDeductCents Int @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generatedById String?
  generatedBy   User?    @relation("BillGeneratedBy", fields: [generatedById], references: [id])

  lineItems     BillLineItem[]

  @@unique([assetId, year, month])
  @@index([periodKey, status])
  @@index([projectId, periodKey])
}

model BillLineItem {
  id          String  @id @default(uuid())

  billId      String
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)

  kind        String  // "RENTAL" | "FUEL" | "ADJUSTMENT"
  description String
  quantity    Float
  unit        String  // "hr" | "km" | "day" | "L" | "—"
  unitRateCents Int
  amountCents Int

  // Per-site attribution. When a vehicle works several sites in one month the
  // bill carries one RENTAL (+ optional FUEL) line per site; these record which
  // site the line belongs to. Null for single-site / legacy bills.
  projectId   String?
  projectName String?

  @@index([billId])
}
